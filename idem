    <script>
        // Menu Mobile
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');

        hamburger.addEventListener('click', () => {
            navMenu.classList.toggle('active');
        });

        document.querySelectorAll('.nav-menu a').forEach(link => {
            link.addEventListener('click', () => {
                navMenu.classList.remove('active');
            });
        });

        // Smooth Scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // Modal Doação
        const modal = document.getElementById('modalDoacao');
        const btnDoadorNav = document.getElementById('btnDoadorNav');
        const btnDoadorHero = document.getElementById('btnDoadorHero');
        const btnDoadorHero2 = document.getElementById('btnDoadorHero2');
        const btnDoadorCta = document.getElementById('btnDoadorCta');
        const closeModal = document.querySelector('.modal-close');

        function abrirModal(e) {
            e.preventDefault();
            modal.style.display = 'flex';
        }

        btnDoadorNav?.addEventListener('click', abrirModal);
        btnDoadorHero?.addEventListener('click', abrirModal);
        btnDoadorHero2?.addEventListener('click', abrirModal);
        btnDoadorCta?.addEventListener('click', abrirModal);

        closeModal?.addEventListener('click', () => {
            modal.style.display = 'none';
        });

        window.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.style.display = 'none';
            }
        });

        function copiarPix() {
            const pix = '41.572.637/0001-30';
            navigator.clipboard.writeText(pix).then(() => {
                alert('Chave PIX copiada com sucesso!');
            });
        }

        // Botões Padrinho
        const btnPadrinhoNav = document.getElementById('btnPadrinhoNav');
        const btnPadrinhoHero = document.getElementById('btnPadrinhoHero');
        const btnPadrinhoCta = document.getElementById('btnPadrinhoCta');

        function abrirPadrinho(e) {
            e.preventDefault();
            alert('Em breve você poderá se cadastrar como padrinho! Entre em contato conosco para mais informações.');
        }

        btnPadrinhoNav?.addEventListener('click', abrirPadrinho);
        btnPadrinhoHero?.addEventListener('click', abrirPadrinho);
        btnPadrinhoCta?.addEventListener('click', abrirPadrinho);

        // Botão Transparência
        const btnTransparenciaNav = document.getElementById('btnTransparenciaNav');
        
        btnTransparenciaNav?.addEventListener('click', (e) => {
            e.preventDefault();
            alert('Portal da Transparência em desenvolvimento. Em breve você poderá acompanhar todas as nossas prestações de contas!');
        });
    </script>
